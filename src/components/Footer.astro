---
const year = new Date().getFullYear();
---
<footer style="background: oklch(0.07 0.012 265); border-top: 1px solid oklch(0.72 0.10 82 / 0.12);">
  <div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16 py-16">

    <!-- Top row: brand + links -->
    <div class="grid md:grid-cols-3 gap-12 mb-14">

      <!-- Brand column -->
      <div>
        <a href="/" class="flex items-center gap-3 mb-4" style="text-decoration: none;">
          <svg width="26" height="18" viewBox="0 0 56 36" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="28" cy="18" r="10" fill="oklch(0.14 0.025 272)" stroke="oklch(0.72 0.10 82)" stroke-width="1.5"/>
            <ellipse cx="28" cy="18" rx="27" ry="7.5" stroke="oklch(0.72 0.10 82)" stroke-width="1.5" fill="none"/>
          </svg>
          <span class="font-display text-base tracking-wide" style="color: oklch(0.88 0.006 80);">Satúrnia</span>
        </a>
        <p class="font-body font-300 text-sm leading-relaxed mb-5" style="color: oklch(0.52 0.010 80);">
          Maquillaje premium inspirado en los anillos de Saturno. Cruelty-free, para quienes brillan diferente.
        </p>
        <!-- Social icons -->
        <div class="flex gap-4">
          <a href="#" aria-label="Instagram" style="color: oklch(0.55 0.010 80);"
             onmouseover="this.style.color='oklch(0.72 0.10 82)'"
             onmouseout="this.style.color='oklch(0.55 0.010 80)'">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
            </svg>
          </a>
          <a href="#" aria-label="TikTok" style="color: oklch(0.55 0.010 80);"
             onmouseover="this.style.color='oklch(0.72 0.10 82)'"
             onmouseout="this.style.color='oklch(0.55 0.010 80)'">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05A6.34 6.34 0 003.15 15.3a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.62a8.17 8.17 0 004.78 1.52V6.7a4.85 4.85 0 01-1.01-.01z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links col 1 -->
      <div>
        <h4 class="font-body font-500 text-xs tracking-widest uppercase mb-5" style="color: oklch(0.72 0.10 82); letter-spacing: 0.18em;">Colección</h4>
        <ul class="space-y-3">
          <li><a href="#coleccion" class="font-body font-300 text-sm transition-colors duration-150" style="color: oklch(0.55 0.010 80);" onmouseover="this.style.color='oklch(0.78 0.09 82)'" onmouseout="this.style.color='oklch(0.55 0.010 80)'">Paletas de ojos</a></li>
          <li><a href="#coleccion" class="font-body font-300 text-sm transition-colors duration-150" style="color: oklch(0.55 0.010 80);" onmouseover="this.style.color='oklch(0.78 0.09 82)'" onmouseout="this.style.color='oklch(0.55 0.010 80)'">Labiales Lunar Matte</a></li>
          <li><a href="#coleccion" class="font-body font-300 text-sm transition-colors duration-150" style="color: oklch(0.55 0.010 80);" onmouseover="this.style.color='oklch(0.78 0.09 82)'" onmouseout="this.style.color='oklch(0.55 0.010 80)'">Highlighters Titan</a></li>
          <li><a href="#cta" class="font-body font-300 text-sm transition-colors duration-150" style="color: oklch(0.55 0.010 80);" onmouseover="this.style.color='oklch(0.78 0.09 82)'" onmouseout="this.style.color='oklch(0.55 0.010 80)'">Próximos lanzamientos</a></li>
        </ul>
      </div>

      <!-- Links col 2 -->
      <div>
        <h4 class="font-body font-500 text-xs tracking-widest uppercase mb-5" style="color: oklch(0.72 0.10 82); letter-spacing: 0.18em;">Empresa</h4>
        <ul class="space-y-3">
          <li><a href="#historia" class="font-body font-300 text-sm transition-colors duration-150" style="color: oklch(0.55 0.010 80);" onmouseover="this.style.color='oklch(0.78 0.09 82)'" onmouseout="this.style.color='oklch(0.55 0.010 80)'">Nuestra historia</a></li>
          <li><a href="#cta" class="font-body font-300 text-sm transition-colors duration-150" style="color: oklch(0.55 0.010 80);" onmouseover="this.style.color='oklch(0.78 0.09 82)'" onmouseout="this.style.color='oklch(0.55 0.010 80)'">Contacto</a></li>
          <li><a href="#" class="font-body font-300 text-sm transition-colors duration-150" style="color: oklch(0.55 0.010 80);" onmouseover="this.style.color='oklch(0.78 0.09 82)'" onmouseout="this.style.color='oklch(0.55 0.010 80)'">Política de envíos</a></li>
          <li><a href="#" class="font-body font-300 text-sm transition-colors duration-150" style="color: oklch(0.55 0.010 80);" onmouseover="this.style.color='oklch(0.78 0.09 82)'" onmouseout="this.style.color='oklch(0.55 0.010 80)'">Devoluciones</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 flex flex-col md:flex-row items-center justify-between gap-4" style="border-top: 1px solid oklch(0.72 0.10 82 / 0.10);">
      <p class="font-body font-300 text-xs" style="color: oklch(0.42 0.008 80); letter-spacing: 0.04em;">
        &copy; {year} Satúrnia. Todos los derechos reservados.
      </p>
      <p class="font-body font-300 text-xs" style="color: oklch(0.38 0.008 80); letter-spacing: 0.04em;">
        Cruelty-free &nbsp;·&nbsp; Hecho con amor por el cosmos
      </p>
    </div>
  </div>
</footer>
