---
---
<header class="sticky top-0 z-50" style="background: oklch(0.08 0.015 265 / 0.85); border-bottom: 1px solid oklch(0.72 0.10 82 / 0.12); backdrop-filter: blur(20px) saturate(1.15);">
  <nav class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16 h-16 flex items-center justify-between">

    <!-- Logotype -->
    <a href="/" class="flex items-center gap-3 group" style="text-decoration: none;">
      <!-- Saturn micro-icon -->
      <svg width="28" height="20" viewBox="0 0 56 36" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink:0;">
        <circle cx="28" cy="18" r="10" fill="oklch(0.14 0.025 272)" stroke="oklch(0.72 0.10 82)" stroke-width="1.5"/>
        <ellipse cx="28" cy="18" rx="27" ry="7.5" stroke="oklch(0.72 0.10 82)" stroke-width="1.5" fill="none"/>
        <ellipse cx="28" cy="18" rx="21" ry="5.5" stroke="oklch(0.86 0.07 82)" stroke-width="0.75" fill="none"/>
      </svg>
      <!-- Wordmark -->
      <span class="font-display text-lg tracking-wide" style="color: oklch(0.92 0.006 80); letter-spacing: 0.04em;">
        Sat<em class="not-italic text-gold-shimmer">ú</em>rnia
      </span>
    </a>

    <!-- Nav links -->
    <div class="hidden md:flex items-center gap-8">
      <a href="#historia" class="font-body font-300 text-sm transition-colors duration-150"
         style="color: oklch(0.62 0.010 80); letter-spacing: 0.06em;"
         onmouseover="this.style.color='oklch(0.78 0.09 82)'"
         onmouseout="this.style.color='oklch(0.62 0.010 80)'">
        Historia
      </a>
      <a href="#coleccion" class="font-body font-300 text-sm transition-colors duration-150"
         style="color: oklch(0.62 0.010 80); letter-spacing: 0.06em;"
         onmouseover="this.style.color='oklch(0.78 0.09 82)'"
         onmouseout="this.style.color='oklch(0.62 0.010 80)'">
        Colección
      </a>
      <a href="#cta" class="btn-gold" style="padding: 0.55rem 1.4rem; font-size: 0.75rem;">
        Únete
      </a>
    </div>

    <!-- Mobile menu button -->
    <button class="md:hidden p-2 rounded" style="color: oklch(0.72 0.10 82);" aria-label="Menú">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <line x1="3" y1="7" x2="21" y2="7"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="17" x2="21" y2="17"/>
      </svg>
    </button>

  </nav>
</header>
